<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>LiveSplit</RootNamespace>
    <OutputType>WinExe</OutputType>
    <UseWindowsForms>true</UseWindowsForms>

    <!-- Windows-only file-association registry utility. The project's contents (file-type
         associations + IE compatibility-view registry tweaks) only make sense on Windows.
         On non-Windows hosts MSBuild won't be able to reference System.Windows.Forms /
         Microsoft.Win32, so the project is excluded from the build entirely on those hosts:
         - All source files are dropped (see ItemGroup below)
         - Output type relaxes to Library so the empty assembly compiles cleanly
         Linux file associations are handled via .desktop + xdg-mime in the AppImage /
         tarball packaging from Phase 8. -->
  </PropertyGroup>

  <PropertyGroup Condition="'$(OS)' != 'Windows_NT'">
    <UseWindowsForms>false</UseWindowsForms>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup Condition="'$(OS)' != 'Windows_NT'">
    <Compile Remove="**/*.cs" />
    <Compile Include="LinuxNoOp.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(SrcPath)\LiveSplit.Core\LiveSplit.Core.csproj" />
  </ItemGroup>

</Project>
