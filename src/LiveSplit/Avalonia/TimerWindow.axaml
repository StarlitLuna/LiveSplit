<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:LiveSplit.Avalonia"
        x:Class="LiveSplit.Avalonia.TimerWindow"
        Title="LiveSplit"
        Width="300" Height="500"
        Background="#101214"
        CanResize="True">
  <Window.KeyBindings>
    <KeyBinding Gesture="Space" Command="{Binding SplitCommand}" />
    <KeyBinding Gesture="R" Command="{Binding ResetCommand}" />
    <KeyBinding Gesture="N" Command="{Binding SkipCommand}" />
    <KeyBinding Gesture="B" Command="{Binding UndoCommand}" />
    <KeyBinding Gesture="P" Command="{Binding PauseCommand}" />
  </Window.KeyBindings>
  <Window.ContextMenu>
    <ContextMenu>
      <MenuItem Header="Edit Splits…" Command="{Binding EditSplitsCommand}" />
      <MenuItem Header="Edit Layout…" Command="{Binding EditLayoutCommand}" />
      <MenuItem Header="Layout Settings…" Command="{Binding LayoutSettingsCommand}" />
      <Separator />
      <MenuItem Header="Settings…" Command="{Binding SettingsCommand}" />
      <MenuItem Header="Set Size…" Command="{Binding SetSizeCommand}" />
      <Separator />
      <MenuItem Header="About" Command="{Binding AboutCommand}" />
      <MenuItem Header="Close" Command="{Binding CloseCommand}" />
    </ContextMenu>
  </Window.ContextMenu>
  <local:SkiaRenderControl Name="Canvas" />
</Window>
